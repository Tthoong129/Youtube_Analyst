{
  "name": "YouTube Pro Red Palette",
  "dataColors": [
    "#D32F2F",
    "#EF5350",
    "#FF6F61",
    "#FF8A80",
    "#F06292",
    "#FFAAAA"
  ],
  "background": "#FFFFFF",
  "foreground": "#2E2E2E",
  "tableAccent": "#D32F2F",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F6F6F6" } },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#EEEEEE" } },
            "radius": 12
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#000000" } },
            "blur": 10,
            "transparency": 88
          }
        ]
      }
    }
  }
}
